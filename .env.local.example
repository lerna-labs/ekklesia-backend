# Local environment overrides — copy to `.env.local` to use.
#
# Loaded AFTER `.env.${NODE_ENV}` with `override: true`, so anything set here
# wins. Host-owned, gitignored. Use this to persist local dev overrides
# without them being clobbered by the docs docker-compose rewriting
# `.env.development` at container startup.

# Example: point Mongo at the docs docker-compose instance from the host
# MONGODB_HOST=localhost
# MONGODB_PORT=27017
# MONGODB_USERNAME=devuser
# MONGODB_PASSWORD=devpassword

# Example: a Hydra instance on your LAN
# HYDRA_DEFAULT_ENDPOINT=https://hydra.preprod.mylab.internal
# HYDRA_DEFAULT_API_KEY=local-dev-key

# Preprod dump address used by `node __scripts/sweepAdminWallet.js` to
# consolidate the Hydra admin wallet between test runs. Any wallet address
# you control on preprod is fine — swept tokens end up here so the admin
# wallet returns to a clean single-UTxO state.
# HYDRA_SWEEP_ADDRESS=addr_test1...

# Example: override Koios to a private proxy
# API_URL=https://koios.mylab.internal/api/v1
# API_TOKEN=...
