# Express configuration
SERVER_PORT=3000

# Network config
NETWORK_ID=0
NETWORK_NAME=preprod

# MongoDB configuration
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=hydra-voting-dev
MONGODB_USERNAME=devuser
MONGODB_PASSWORD=devpassword
MONGODB_AUTH_SOURCE=admin

# JWT configuration
JWT_SECRET=secret
JWT_MAX_AGE=3600s # takes seconds, hours or days as suffix

# API configuration for external services
API_URL=https://api.koios.rest/api/v1
API_TOKEN=your_api_token_here

# Enable or disable display of votes per voter
PUBLIC_VOTING=1 # 0 | 1

# Enable or disable display of progress during voting
PUBLIC_PROGRESS=1 # 0 | 1

# Enable or disable allowList for login
SYSTEM_ALLOWLIST=1 # 0 | 1