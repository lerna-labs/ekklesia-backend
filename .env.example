# Express configuration
SERVER_PORT=3000

# Network config
NETWORK_ID=0
NETWORK_NAME=preprod

# MongoDB configuration
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=hydra-voting-dev
MONGODB_USERNAME=devuser
MONGODB_PASSWORD=devpassword
MONGODB_AUTH_SOURCE=admin

# JWT configuration
JWT_SECRET=secret
JWT_MAX_AGE=3600s # takes seconds, hours or days as suffix

# HYDRA (legacy OAuth) configuration
HYDRA_URL=http://localhost:4445
HYDRA_TOKEN=your_hydra_token_here

# Hydra integration service (~/ekklesia/hydra)
# Default endpoint used by admin /prepare and scaffolds when a ballot
# doesn't already have a hydraEndpoint associated.
HYDRA_DEFAULT_ENDPOINT=http://localhost:3030
# Per-endpoint Hydra middleware API key. The middleware issues a unique
# key per head, so each Hydra endpoint URL needs its own variable. The
# env-var name is derived from the full endpoint URL: every run of
# non-alphanumeric characters collapses to a single "_", then upper-case.
# Example: http://10.0.0.5:7001  →  HYDRA_API_KEY_HTTP_10_0_0_5_7001
# There is no global default — a missing var fails fast with NO_API_KEY.
HYDRA_API_KEY_HTTP_LOCALHOST_3030=your_hydra_service_api_key

# Admin gate — comma-separated bech32 userIds that bypass the
# role=="admin" JWT claim check. Provisional; to be replaced with
# a proper role model.
ADMIN_USER_IDS=

# Public API (integrator) rate-limit defaults. Per-key overrides are stored
# on the ApiKey doc; these env vars apply when no override is set.
PUBLIC_API_WINDOW_MS=60000
PUBLIC_API_MAX=120

# Rate limit for POST /api/v1/admin/ballots/import. Tight by design;
# this is a mutating endpoint and push traffic should be bursty-on-publish,
# not continuous.
BALLOT_IMPORT_WINDOW_MS=60000
BALLOT_IMPORT_MAX=30

# Set to "true" to wrap compiled-ballot imports in a Mongo transaction
# (requires a replica set). Dev / standalone mongo leaves this unset;
# the worst-case failure is an interrupted import requiring a re-push.
MONGO_USE_TRANSACTIONS=false

# API configuration for external services
API_URL=https://api.koios.rest/api/v1
API_TOKEN=your_api_token_here

# Enable or disable display of votes per voter
PUBLIC_VOTING=1 # 0 | 1

# Enable or disable display of progress during voting
PUBLIC_PROGRESS=1 # 0 | 1

# Enable or disable allowList for login
SYSTEM_ALLOWLIST=1 # 0 | 1

# Runtime config returned by GET /api/v1/config — lets the frontend and
# third-party integrators render explorer + IPFS links without hardcoding
# a network. All four have safe defaults; override per deployment.
IPFS_GATEWAY_BASE=https://ipfs.io/ipfs/
EXPLORER_TX_BASE=https://cexplorer.io/tx/
EXPLORER_ADDRESS_BASE=https://cexplorer.io/address/
CARDANO_NETWORK=preprod # preprod | preview | mainnet

# OpenGraph cards. When OG_CARDS_ENABLED=true, the backend mounts:
#   /og/ballot/:id.png + /og/proposal/:id.png   (Satori + @resvg/resvg-js)
#   per-route OG/Twitter meta injection on /ballots/:id and proposal URLs
# Requires `satori` + `@resvg/resvg-js` installed and Inter Regular/Bold
# TTFs at assets/og/ (or override via OG_FONT_REGULAR / OG_FONT_BOLD).
# PUBLIC_URL is the absolute base URL the meta tags will reference;
# falls back to FRONTEND_URL if unset.
OG_CARDS_ENABLED=false
PUBLIC_URL=
# OG_FONT_REGULAR=assets/og/Inter-Regular.ttf
# OG_FONT_BOLD=assets/og/Inter-Bold.ttf
# Bump after changing the card design or PUBLIC_URL to bust every
# downstream cache (in-process LRU + browser/CDN ?v=…). Defaults to "1".
# OG_RENDERER_VERSION=1
# Bottom-row branding on the rendered card. OG_BRAND_HOST defaults to
# the host parsed from PUBLIC_URL (or FRONTEND_URL); set explicitly to
# override (e.g. a vanity domain). OG_BRAND_NAME defaults to "EKKLESIA".
# OG_BRAND_HOST=
# OG_BRAND_NAME=EKKLESIA
# Per-deployment color palette. Path to a JSON file (absolute or
# repo-relative) whose keys override DEFAULT_PALETTE in
# helper/og/ogImage.js. Common keys: bgFrom / bgVia / bgTo (background
# gradient stops), brandPrimary / brandSecondary (accent + glow source),
# textPrimary / textSecondary. Bump OG_RENDERER_VERSION after editing
# the file to bust downstream caches.
# OG_PALETTE_FILE=assets/og/palette.json