{
  "name": "ekklesia-backend",
  "version": "0.9.2",
  "main": "server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start:dev": "NODE_ENV=development nodemon --watch '**/*.js' --ignore 'node_modules/' server.js",
    "start:prod": "NODE_ENV=production nodemon --watch '**/*.js' --ignore 'node_modules/' server.js",
    "backup:dev": "NODE_ENV=development node backup/backup.js",
    "backup:prod": "NODE_ENV=production node backup/backup.js",
    "test": "node --experimental-vm-modules ./node_modules/.bin/jest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:tag": "node scripts/tag-release.mjs",
    "changeset:snapshot": "changeset version --snapshot rc"
  },
  "type": "module",
  "keywords": [],
  "author": "Mad Orkestra & Adam Dean for Lerna Labs",
  "homepage": "https://github.com/lerna-labs/ekklesia-backend",
  "license": "Apache-2.0",
  "description": "Ekklesia Voting Backend",
  "dependencies": {
    "@emurgo/cardano-serialization-lib-nodejs": "^15.0.3",
    "@lerna-labs/ekklesia-helpers": "^1.1.0",
    "@meshsdk/common": "^1.9.0-beta.101",
    "@meshsdk/core": "^1.9.0-beta.101",
    "@resvg/resvg-js": "^2.6.2",
    "autocannon": "^8.0.0",
    "bech32": "^2.0.0",
    "blakejs": "^1.2.1",
    "cbor": "^10.0.12",
    "compress": "^0.99.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dayjs": "^1.11.20",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "fast-sort": "^3.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "merkletreejs": "^0.6.0",
    "mongoose": "^9.3.0",
    "satori": "^0.12.2",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@babel/preset-env": "^7.29.2",
    "@changesets/cli": "^2.31.1",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "babel-jest": "^30.2.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.9",
    "prettier": "^3.9.5"
  }
}
